# ─────────────────────────────────────────────────────────────────────────────
# E2E test credentials
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.test and fill in real credentials.
# .env.test is gitignored — never commit real passwords.

# Active user account for authenticated page tests
E2E_EMAIL=your-email@example.com
E2E_PASSWORD=your-password

# Frontend dev server URL (default: http://localhost:5173)
# E2E_BASE_URL=http://localhost:5173
